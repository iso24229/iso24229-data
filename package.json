{
  "name": "@iso24229/iso24229-data",
  "type": "module",
  "version": "0.1.0",
  "description": "ISO 24229 register data — writing system conversion systems (public mirror of register entries)",
  "repository": {
    "type": "git",
    "url": "https://github.com/iso24229/iso24229-data.git"
  },
  "main": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "validate": "node scripts/validate.mjs"
  },
  "files": [
    "authority",
    "code-status",
    "spelling-system",
    "system-code",
    "system-relation",
    "system-relation-type",
    "system-status",
    "schema",
    "README.adoc",
    "SCHEMA.adoc",
    "index.mjs",
    "index.d.ts"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
